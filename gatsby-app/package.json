    "react-redux": "^7.2.3",
    "redux": "^4.0.5"
  },
  "devDependencies": {
    "@tailwindcss/jit": "^0.1.14",
    "autoprefixer": "^10.2.5",
    "gatsby-plugin-postcss": "^4.1.0",
    "postcss": "^8.2.8",
    "prettier": "2.2.1",
    "tailwindcss": "^2.1.2"
  },
  "repository": {
    "type": "git",
